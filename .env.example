# Copy to .env and fill in real values. NEVER commit .env to git.
# ⚠️ 이 파일(.env.example)은 git이 추적합니다 — 절대 실제 키/토큰을 넣지 마세요!
#    실제 값은 .env (gitignore됨)에만. 여기는 형식 예시(플레이스홀더)만 둡니다.

# ── 한국투자증권 KIS Open API (REST) ──────────────────────────────────────
# 발급: apiportal.koreainvestment.com → 신청 → App Key / App Secret
KIS_APP_KEY=PSxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KIS_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KIS_ACCOUNT_NO=00000000-01     # 계좌번호 (8자리-2자리 형식 또는 전체)
KIS_ENV=real                    # real(실전) | paper(모의) — 데이터/조회용. real 권장(모의 도메인 OHLCV 500 빈발)

# 모의투자 전용 키 — auto_trader 주문 전용 (데이터는 위 real 키로 조회).
# KIS는 실전/모의 키가 별개. 발급: apiportal → 모의투자 신청 → 별도 App Key/Secret.
# 미설정 시 auto_trader 는 중단(주문 불가). 리포트/조회만 쓰면 비워둬도 됨.
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_PAPER_ACCOUNT_NO=00000000-01

# # Kiwoom OpenAPI+ (레거시 — 현재 미사용, OCX 환경에서만)
# KIWOOM_ACCOUNT_NO=00000000000  # 계좌번호 (숫자만, 하이픈 제외)
# KIWOOM_ENV=real                 # real(실전) | paper(모의투자)

# Telegram (발급: @BotFather → /newbot, 토큰 노출 시 /revoke 로 즉시 재발급)
TELEGRAM_BOT_TOKEN=0000000000:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TELEGRAM_ALLOWED_CHAT_IDS=000000000  # 본인 chat_id (콤마로 여러개 가능)

# Google Gemini (무료 키 발급: aistudio.google.com → Get API key)
GEMINI_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# 아래는 기본값 있음 — 필요할 때만 변경
AI_DAILY_CALL_LIMIT=100
DB_PATH=data/stock_bot.db
