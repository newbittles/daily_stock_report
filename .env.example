# Copy to .env and fill in real values. NEVER commit .env to git.

# Kiwoom OpenAPI+ (OCX/COM 기반 — 앱키/시크릿 없음)
# 인증은 CommConnect() 호출 시 HTS 로그인 팝업으로 처리
KIWOOM_ACCOUNT_NO=50123456789  # 계좌번호 (숫자만, 하이픈 제외)
KIWOOM_ENV=real                 # real(실전) | paper(모의투자)

# Telegram
TELEGRAM_BOT_TOKEN=123456789:AAF_your_token_here
TELEGRAM_ALLOWED_CHAT_IDS=987654321  # 본인 chat_id (콤마로 여러개 가능)

# Google Gemini (무료 키 발급: aistudio.google.com → Get API key)
GEMINI_API_KEY=AIza_your_key_here

# 아래는 기본값 있음 — 필요할 때만 변경
AI_DAILY_CALL_LIMIT=100
DB_PATH=data/stock_bot.db
